<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="is_scan_deplacement_charge_form" model="ir.ui.view">
            <field name="name">is_scan_deplacement_charge_form</field>
            <field name="model">is.scan.deplacement.charge</field>
            <field name="arch" type="xml">
                <form create="false">
                    <header>
                        <button 
                            name="terminer_action" 
                            string="Terminer" 
                            type="object" 
                            class="btn-primary"
                            attrs="{'invisible': [('state', '=', 'termine')]}"
                            confirm="Êtes-vous sûr de vouloir terminer cette session de déplacement de charges ?"
                        />
                        <button 
                            name="voir_mouvements_action" 
                            string="Tous les mouvements" 
                            type="object" 
                            class="btn-secondary"
                            attrs="{'invisible': [('move_ids', '=', [])]}"
                        />
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group attrs="{'invisible': [('state', '!=', 'termine')]}">
                            <group>
                                <field name="create_uid" string="Créé par" readonly="1"/>
                                <field name="create_date" string="Date de création" readonly="1"/>
                            </group>
                            <group>
                                <field name="write_date" string="Dernière modification" readonly="1"/>
                            </group>
                        </group>
                        
                        <div class="alert alert-success text-center" role="alert" attrs="{'invisible': [('state', '!=', 'lot')]}">
                            <field name="message_scan" nolabel="1" readonly="1"/>
                        </div>
                        <div class="alert alert-info text-center" role="alert" attrs="{'invisible': [('state', '!=', 'emplacement')]}">
                            <field name="message_scan" nolabel="1" readonly="1"/>
                        </div>

                        <field name="alert_type" invisible="1"/>
                        <div class="alert alert-success text-center" role="alert" attrs="{'invisible': ['|', ('alert_message', '=', False), ('alert_type', '!=', 'success')]}">
                            <field name="alert_message" nolabel="1" readonly="1"/>
                        </div>
                        <div class="alert alert-warning text-center" role="alert" attrs="{'invisible': ['|', ('alert_message', '=', False), ('alert_type', '!=', 'warning')]}">
                            <field name="alert_message" nolabel="1" readonly="1"/>
                        </div>
                        
                        <group>
                            <field 
                                name="barcode_input" 
                                widget="barcode_scan_widget" nolabel="1" colspan="2"
                                attrs="{'invisible': [('state', '=', 'termine')]}"
                            />
                            <field name="barcode_scan" invisible="1"/>
                        </group>
                        
                        <group col="4" attrs="{'invisible': [('lot_id', '=', False)]}">
                            <field name="lot_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="emplacement_src_id" readonly="1"/>
                            <field name="emplacement_dst_id" readonly="1"/>
                        </group>

                        <notebook>
                            <page string="10 derniers mouvements" attrs="{'invisible': [('move_count', '=', 0)]}">
                                <field name="move_count" invisible="1"/>
                                <field name="move_ids" nolabel="1">
                                    <tree limit="10">
                                        <field name="create_date" string="Date"/>
                                        <field name="name"/>
                                        <field name="product_id"/>
                                        <field name="product_uom_qty"/>
                                        <field name="location_id"/>
                                        <field name="location_dest_id"/>
                                        <field name="state" widget="badge" 
                                            decoration-info="state == 'draft'" 
                                            decoration-warning="state in ('waiting', 'confirmed', 'assigned')" 
                                            decoration-success="state == 'done'"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="is_scan_deplacement_charge_tree" model="ir.ui.view">
            <field name="name">is_scan_deplacement_charge_tree</field>
            <field name="model">is.scan.deplacement.charge</field>
            <field name="arch" type="xml">
                <tree create="false" decoration-info="state == 'lot'" decoration-warning="state == 'emplacement'" decoration-success="state == 'termine'">
                    <field name="id"/>
                    <field name="create_uid"         string="Créé par"      optional="show"/>
                    <field name="create_date"        string="Créé le"       optional="show"/>
                    <field name="write_uid"          string="Modifié par"  optional="show"/>
                    <field name="write_date"         string="Modifié le"   optional="show"/>
                    <field name="move_count"         string="Nb mouvements"/>
                    <field name="state" widget="badge" 
                        decoration-info="state == 'lot'" 
                        decoration-warning="state == 'emplacement'" 
                        decoration-success="state == 'termine'"/>
                </tree>
            </field>
        </record>

        <record id="is_scan_deplacement_charge_search" model="ir.ui.view">
            <field name="name">is_scan_deplacement_charge_search</field>
            <field name="model">is.scan.deplacement.charge</field>
            <field name="arch" type="xml">
                <search>
                    <field name="lot_id"/>
                    <field name="product_id"/>
                    <field name="emplacement_src_id"/>
                    <field name="emplacement_dst_id"/>
                    <field name="state"/>
                    <filter string="Terminé" name="filter_termine" domain="[('state','=','termine')]"/>
                    <filter string="En cours" name="filter_encours" domain="[('state','in',('lot', 'emplacement'))]"/>
                </search>
            </field>
        </record>

        <!-- Action qui crée automatiquement un nouveau record et ouvre le formulaire -->
        <record id="is_scan_deplacement_charge_new_action" model="ir.actions.server">
            <field name="name">Nouveau déplacement de charge</field>
            <field name="model_id" ref="model_is_scan_deplacement_charge"/>
            <field name="state">code</field>
            <field name="code">
record = env['is.scan.deplacement.charge'].create({'state': 'lot'})
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'is.scan.deplacement.charge',
    'res_id': record.id,
    'view_mode': 'form',
    'target': 'current',
}
            </field>
        </record>

        <!-- Action historique (liste des sessions précédentes) -->
        <record id="is_scan_deplacement_charge_action" model="ir.actions.act_window">
            <field name="name">Historique déplacements</field>
            <field name="res_model">is.scan.deplacement.charge</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
